{
  "name": "opencode-ultracode-workflow-plugin",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "files": [
    ".opencode",
    "src",
    "docs",
    "scripts/validate-assets.ts",
    "README.md",
    "install.sh",
    "eslint.config.js",
    "dagger.json",
    ".dagger",
    ".githooks",
    "opencode.json",
    "pnpm-workspace.yaml"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "eslint": "eslint .",
    "lint": "dagger call lint --source .",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "validate:assets": "tsx scripts/validate-assets.ts",
    "check": "pnpm run build && pnpm run lint && pnpm run test && pnpm run validate:assets"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "pnpm@11.4.0"
}
